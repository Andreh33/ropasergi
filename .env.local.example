# URL pública del sitio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contraseña del panel /admin (cámbiala en producción)
ADMIN_PASSWORD=culto-sevilla

# Vercel Blob — necesario para subir fotos en producción.
# Crea un Blob Store en el dashboard de Vercel (Storage → Blob) y pega aquí el token,
# o ejecuta `vercel env pull` tras vincular el proyecto.
# Sin este token, en desarrollo las fotos se guardan en /public/uploads.
BLOB_READ_WRITE_TOKEN=
